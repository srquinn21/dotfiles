[color]
	ui = true
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = green
[format]
	pretty = format:%C(blue)%ad%Creset %C(yellow)%h%C(green)%d%Creset %C(blue)%s %C(magenta) [%an]%Creset
[mergetool]
	prompt = false
[merge]
	summary = true
	verbosity = 1
	tool = nvimdiff
[apply]
	whitespace = nowarn
[branch]
	autosetupmerge = true
[push]
	default = upstream
[core]
	autocrlf = false
	editor = nvim
	pager = less -FMRiX
	excludesfile = ~/.gitignore
[advice]
	statusHints = false
[diff]
	mnemonicprefix = true
	algorithm = patience
[rerere]
	enabled = true
[include]
	path = ~/.gitconfig.user
[alias]
	dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)\"%an\" <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
