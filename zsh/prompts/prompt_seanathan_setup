#
# A minimal prompt based on sorin, with SSH cloud indicator and single-line vi mode.
#
# Based on sorin by Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Load dependencies.
pmodload 'helper'

function prompt_seanathan_async_callback {
  case $1 in
    prompt_seanathan_async_git)
      IFS=':' read _git_target _git_post_target <<<"$3"
      _git_target=$(coalesce ${(@)${(z)_git_target}})

      if [[ -z "$_git_target" ]]; then
        if [[ -n "$_prompt_seanathan_git" ]]; then
          _prompt_seanathan_git=''
          zle && zle reset-prompt
        fi
      else
        _prompt_seanathan_git="${_git_target}${_git_post_target}"
        zle && zle reset-prompt
      fi
      ;;
    "[async]")
      if [[ $2 -eq 2 ]]; then
        typeset -g prompt_prezto_async_init=0
      fi
      ;;
  esac
}

function prompt_seanathan_async_git {
  cd -q "$1"
  if (( $+functions[git-info] )); then
    git-info
    print ${git_info[status]}
  fi
}

function prompt_seanathan_async_tasks {
  if (( !${prompt_prezto_async_init:-0} )); then
    async_start_worker prompt_seanathan -n
    async_register_callback prompt_seanathan prompt_seanathan_async_callback
    typeset -g prompt_prezto_async_init=1
  fi

  async_flush_jobs prompt_seanathan
  async_job prompt_seanathan prompt_seanathan_async_git "$PWD"
}

function prompt_seanathan_precmd {
  setopt LOCAL_OPTIONS
  unsetopt XTRACE KSH_ARRAYS

  if (( $+functions[git-dir] )); then
    local new_git_root="$(git-dir 2> /dev/null)"
    if [[ $new_git_root != $_seanathan_cur_git_root ]]; then
      _prompt_seanathan_git=''
      _seanathan_cur_git_root=$new_git_root
    fi
  fi

  prompt_seanathan_async_tasks
}

function prompt_seanathan_setup {
  setopt LOCAL_OPTIONS
  unsetopt XTRACE KSH_ARRAYS
  prompt_opts=(cr percent sp subst)

  autoload -Uz add-zsh-hook
  autoload -Uz async && async

  add-zsh-hook precmd prompt_seanathan_precmd

  zstyle ':prezto:module:prompt' managed 'yes'

  # Vi mode indicators
  zstyle ':prezto:module:editor:info:completing' format '%B%F{7}...%f%b'
  zstyle ':prezto:module:editor:info:keymap:primary' format '%B%F{4}❯%f%b'
  zstyle ':prezto:module:editor:info:keymap:primary:overwrite' format ' %F{3}♺%f'
  zstyle ':prezto:module:editor:info:keymap:alternate' format '%B%F{5}❮%f%b'

  # Git info
  zstyle ':prezto:module:git:info' verbose 'yes'
  zstyle ':prezto:module:git:info:action' format '%F{7}:%f%%B%F{9}%s%f%%b'
  zstyle ':prezto:module:git:info:added' format ' %%B%F{2}✚%f%%b'
  zstyle ':prezto:module:git:info:ahead' format ' %%B%F{13}⬆%f%%b'
  zstyle ':prezto:module:git:info:behind' format ' %%B%F{13}⬇%f%%b'
  zstyle ':prezto:module:git:info:branch' format ' %%B%F{2}%b%f%%b'
  zstyle ':prezto:module:git:info:commit' format ' %%B%F{3}%.7c%f%%b'
  zstyle ':prezto:module:git:info:deleted' format ' %%B%F{1}✖%f%%b'
  zstyle ':prezto:module:git:info:modified' format ' %%B%F{4}✱%f%%b'
  zstyle ':prezto:module:git:info:position' format ' %%B%F{13}%p%f%%b'
  zstyle ':prezto:module:git:info:renamed' format ' %%B%F{5}➜%f%%b'
  zstyle ':prezto:module:git:info:stashed' format ' %%B%F{6}✭%f%%b'
  zstyle ':prezto:module:git:info:unmerged' format ' %%B%F{3}═%f%%b'
  zstyle ':prezto:module:git:info:untracked' format ' %%B%F{7}◼%f%%b'
  zstyle ':prezto:module:git:info:keys' format \
    'status' '%b %p %c:%s%A%B%S%a%d%m%r%U%u'

  _seanathan_cur_git_root=''
  _prompt_seanathan_git=''

  # SSH cloud indicator (hidden inside tmux since status bar shows it)
  _prompt_seanathan_ssh=''
  if [[ -n "$SSH_CLIENT" || -n "$SSH_TTY" ]]; then
    _prompt_seanathan_ssh='%F{7}☁️ %f '
  fi

  PROMPT='${_prompt_seanathan_ssh}${editor_info[keymap]} '
  RPROMPT='${_prompt_seanathan_git}'
  SPROMPT='zsh: correct %F{1}%R%f to %F{2}%r%f [nyae]? '
}

function prompt_seanathan_preview {
  local +h PROMPT=''
  local +h RPROMPT=''
  local +h SPROMPT=''

  editor-info 2> /dev/null
  prompt_preview_theme 'seanathan'
}

prompt_seanathan_setup "$@"
